# Allow fp CLI commands in the Codex sandbox
prefix_rule(pattern=["fp"], decision="allow", justification="fp CLI for issue tracking and project management")
prefix_rule(pattern=["fp", "issue", "create"], decision="allow", justification="allow extension-triggered background issue creation")
prefix_rule(pattern=["fp", "comment"], decision="allow", justification="allow extension-triggered background status/review comments")
prefix_rule(pattern=["fp", "issue", "diff"], decision="allow", justification="allow extension-triggered diff reads before review")
prefix_rule(pattern=["fp", "comment", "list"], decision="allow", justification="allow extension-triggered comment context reads")

# Allow codex spawned by fp extension for detached background review runs
prefix_rule(pattern=["codex", "exec"], decision="allow", justification="allow codex-review extension to run detached background reviews")

# Allow npm metadata lookups used by automation diagnostics/changelog checks
prefix_rule(pattern=["npm", "view"], decision="allow", justification="npm registry metadata lookups for automation runs")
prefix_rule(pattern=["npm", "info"], decision="allow", justification="npm registry package info lookups for automation runs")
prefix_rule(pattern=["bun", "x", "npm", "view"], decision="allow", justification="npm registry metadata lookups via bun x for automation runs")
prefix_rule(pattern=["bun", "x", "npm", "info"], decision="allow", justification="npm registry package info lookups via bun x for automation runs")

# Allow common git read commands
prefix_rule(pattern=["git", "status"], decision="allow")
prefix_rule(pattern=["git", "diff"], decision="allow")
prefix_rule(pattern=["git", "log"], decision="allow")

# Allow bun commands for slides
prefix_rule(pattern=["bun", "run"], decision="allow")
prefix_rule(pattern=["bun", "install"], decision="allow")
prefix_rule(pattern=["bun", "test"], decision="allow")
